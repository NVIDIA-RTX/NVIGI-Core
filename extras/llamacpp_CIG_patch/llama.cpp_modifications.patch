+        # CUDAToolkit_ROOT_DIR is only set on newer CMake; derive root when missing.
+        set(_CUPTI_CUDA_TOOLKIT_ROOT "${CUDAToolkit_ROOT_DIR}")
+        if(NOT _CUPTI_CUDA_TOOLKIT_ROOT AND DEFINED ENV{CUDA_PATH})
+            set(_CUPTI_CUDA_TOOLKIT_ROOT "$ENV{CUDA_PATH}")
+        endif()
+        if(NOT _CUPTI_CUDA_TOOLKIT_ROOT AND CUDAToolkit_BIN_DIR)
+            get_filename_component(_CUPTI_CUDA_TOOLKIT_ROOT "${CUDAToolkit_BIN_DIR}" DIRECTORY)
+        endif()
+        file(GLOB CUPTI_DLL_CANDIDATES
+            "${_CUPTI_CUDA_TOOLKIT_ROOT}/extras/CUPTI/lib64/cupti64*.dll"
+            "${_CUPTI_CUDA_TOOLKIT_ROOT}/extras/CUPTI/lib/cupti64*.dll"
+            "${_CUPTI_CUDA_TOOLKIT_ROOT}/lib/cupti64*.dll"
+            "${CUDAToolkit_BIN_DIR}/cupti64*.dll"
+        )
+        if(CUPTI_DLL_CANDIDATES)
+            list(SORT CUPTI_DLL_CANDIDATES COMPARE STRING ORDER DESCENDING)
+            list(GET CUPTI_DLL_CANDIDATES 0 CUPTI_DLL_PATH)
+            message(STATUS "Found CUPTI DLL: ${CUPTI_DLL_PATH}")
+            add_custom_command(TARGET ${TARGET} POST_BUILD
+                COMMAND ${CMAKE_COMMAND} -E copy_if_different
+                    "${CUPTI_DLL_PATH}"
+                    "$<TARGET_FILE_DIR:${TARGET}>/"
+                COMMENT "Copying CUPTI DLL next to llama-bench"
+            )
+        else()
+            message(WARNING "CUPTI DLL not found under CUDA toolkit (resolved root='${_CUPTI_CUDA_TOOLKIT_ROOT}'). Searched extras/CUPTI/lib64, extras/CUPTI/lib, lib, and bin for cupti64*.dll. Install the full CUDA Toolkit with CUPTI, or copy cupti64_*.dll next to llama-bench.exe manually.")
+        endif()
+    elseif(CUDAToolkit_FOUND AND NOT TARGET CUDA::cupti)
+        message(WARNING "CUDA toolkit found but CUDA::cupti target is missing (CUPTI). llama-bench may fail to link.")
+    endif()
+
+    # Copy cig_scheduler_settings.dll to the output directory
+    set(CIG_SCHEDULER_DLL "${CMAKE_SOURCE_DIR}/../cig_scheduler_settings.dll")
+    if(EXISTS "${CIG_SCHEDULER_DLL}")
+        message(STATUS "Found CIG Scheduler DLL: ${CIG_SCHEDULER_DLL}")
+        add_custom_command(TARGET ${TARGET} POST_BUILD
+            COMMAND ${CMAKE_COMMAND} -E copy_if_different
+                "${CIG_SCHEDULER_DLL}"
+                "$<TARGET_FILE_DIR:${TARGET}>/"
+            COMMENT "Copying cig_scheduler_settings.dll to output directory"
+        )
+    else()
+        message(WARNING "cig_scheduler_settings.dll not found at ${CIG_SCHEDULER_DLL}")
+    endif()
+endif()
+
 if(LLAMA_TOOLS_INSTALL)
     install(TARGETS ${TARGET} RUNTIME)
 endif()
