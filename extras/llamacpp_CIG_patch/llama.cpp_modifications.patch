+// Begin NVidia Modification
+// Match ggml_cuda_flash_attn_ext_mma_f16_case (fattn-mma-f16.cuh): dynamic shared bytes for the MMA FA kernel
+// that would run for this graph, so kernel selection can fall back when nbytes > devices[].smpbo (e.g. CIG).
+static int ggml_cuda_fattn_resolve_ncols1_for_mma(const int cc, const ggml_tensor * Q, const int ncols2) {
+    GGML_ASSERT(ncols2 > 0);
+    if (ncols2 <= 8) {
+        if (turing_mma_available(cc) && Q->ne[1] <= 8 / ncols2) {
+            return 8 / ncols2;
+        }
+    }
+    if (ncols2 <= 16) {
+        if ((turing_mma_available(cc) || amd_wmma_available(cc)) && Q->ne[1] <= 16 / ncols2) {
+            return 16 / ncols2;
+        }
+    }
+    if (ggml_cuda_highest_compiled_arch(cc) == GGML_CUDA_CC_TURING || amd_wmma_available(cc) || Q->ne[1] <= 32 / ncols2) {
+        return 32 / ncols2;
+    }
+    return 64 / ncols2;
+}
+
+static int ggml_cuda_fattn_resolve_ncols2_576_for_mma(
+        const int cc, const ggml_tensor * Q, const ggml_tensor * K, const int64_t gqa_ratio) {
+    if (gqa_ratio == 20) { // GLM 4.7 Flash, mirror ggml_cuda_flash_attn_ext_mma_f16 case 576
+        if (cc >= GGML_CUDA_CC_DGX_SPARK) {
+            return Q->ne[1] <= 8 ? 16 : 4;
+        }
+        if (cc >= GGML_CUDA_CC_BLACKWELL) {
+            return (Q->ne[1] <= 4 && K->ne[1] >= 65536) ? 16 : 4;
+        }
+        if (cc >= GGML_CUDA_CC_ADA_LOVELACE) {
+            return Q->ne[1] <= 4 ? 16 : 4;
+        }
+        if (cc >= GGML_CUDA_CC_TURING) {
+            if (Q->ne[1] <= 4) {
+                return K->ne[1] <= 16384 ? 16 : 32;
+            }
+            return 4;
+        }
+        return 4;
+    }
+    if (gqa_ratio % 16 == 0) {
+        return 16;
+    }
+    return 4;
+}
+
+static int ggml_cuda_fattn_resolve_ncols2_for_mma(
+        const int cc,
+        const ggml_tensor * KQV,
+        const ggml_tensor * Q,
+        const ggml_tensor * K,
+        const ggml_tensor * V,
+        const ggml_tensor * mask,
+        const int DKQ) {
+    float max_bias = 0.0f;
+    memcpy(&max_bias, (const float *) KQV->op_params + 1, sizeof(float));
+
+    bool use_gqa_opt = mask && max_bias == 0.0f && K->ne[1] % FATTN_KQ_STRIDE == 0;
+    for (const ggml_tensor * t : { Q, K, V, mask }) {
+        if (t == nullptr || ggml_is_quantized(t->type)) {
+            continue;
+        }
+        for (size_t i = 1; i < GGML_MAX_DIMS; ++i) {
+            if (t->nb[i] % 16 != 0) {
+                use_gqa_opt = false;
+                break;
+            }
+        }
+    }
+
+    GGML_ASSERT(Q->ne[2] % K->ne[2] == 0);
+    const int gqa_ratio = (int) (Q->ne[2] / K->ne[2]);
+
+    if (DKQ == 576) {
+        GGML_ASSERT(V->ne[0] == 512);
+        GGML_ASSERT(mask && max_bias == 0.0f);
+        return ggml_cuda_fattn_resolve_ncols2_576_for_mma(cc, Q, K, gqa_ratio);
+    }
+
+    if (cc == GGML_CUDA_CC_VOLTA) {
+        if (use_gqa_opt && gqa_ratio % 8 == 0) {
+            return 8;
+        }
+        if (use_gqa_opt && gqa_ratio % 4 == 0) {
+            return 4;
+        }
+        if (use_gqa_opt && gqa_ratio % 2 == 0) {
+            return 2;
+        }
+        return 1;
+    }
+
+    if (use_gqa_opt && gqa_ratio > 4) {
+        return 8;
+    }
+    if (use_gqa_opt && gqa_ratio > 2) {
+        return 4;
+    }
+    if (use_gqa_opt && gqa_ratio > 1) {
+        return 2;
+    }
+    return 1;
+}
+
+static size_t ggml_cuda_fattn_mma_estimated_dynamic_shmem_bytes(const int device, const ggml_tensor * KQV) {
+    const ggml_tensor * Q    = KQV->src[0];
+    const ggml_tensor * K    = KQV->src[1];
+    const ggml_tensor * V    = KQV->src[2];
+    const ggml_tensor * mask = KQV->src[3];
+
+    const int cc            = ggml_cuda_info().devices[device].cc;
+    const int warp_size_host = ggml_cuda_info().devices[device].warp_size;
+
+    const int DKQ = (int) Q->ne[0];
+    const int DV  = (int) V->ne[0];
+
+    const int ncols2 = ggml_cuda_fattn_resolve_ncols2_for_mma(cc, KQV, Q, K, V, mask, DKQ);
+    const int ncols1 = ggml_cuda_fattn_resolve_ncols1_for_mma(cc, Q, ncols2);
+    const int ncols  = ncols1 * ncols2;
+
+    const int  nthreads       = ggml_cuda_fattn_mma_get_nthreads(DKQ, DV, ncols, cc);
+    const int  nbatch_fa      = ggml_cuda_fattn_mma_get_nbatch_fa(DKQ, DV, ncols, cc);
+    const int  nbatch_K2      = ggml_cuda_fattn_mma_get_nbatch_K2(DKQ, DV, ncols, cc);
+    const int  nbatch_V2      = ggml_cuda_fattn_mma_get_nbatch_V2(DKQ, DV, ncols, cc);
+    const int  nbatch_combine = ggml_cuda_fattn_mma_get_nbatch_combine(DKQ, DV, ncols, cc);
+    const bool Q_in_reg       = ggml_cuda_fattn_mma_get_Q_in_reg(DKQ, DV, ncols, cc);
+    const int  nstages        = ggml_cuda_fattn_mma_get_nstages(DKQ, DV, ncols1, ncols2, cc);
+
+    const int cols_per_warp = std::min(ncols, get_cols_per_warp(cc));
+    const int nwarps        = nthreads / warp_size_host;
+
+    // sizeof(half2) == 4 (same as fattn-mma-f16.cuh)
+    const size_t nbytes_shared_KV_1stage = (size_t) nbatch_fa * (size_t) std::max(nbatch_K2 + 4, nbatch_V2 + 4) * 4;
+    const size_t nbytes_shared_KV_2stage = (size_t) nbatch_fa * (size_t) (nbatch_K2 + 4 + nbatch_V2 + 4) * 4;
+    const size_t nbytes_shared_Q           = (size_t) ncols * (size_t) (DKQ / 2 + 4) * 4;
+    const size_t nbytes_shared_mask        = (size_t) ncols1 * (size_t) (nbatch_fa / 2 + 4) * 4;
+    const size_t nbytes_shared_combine     = (size_t) nwarps * (size_t) cols_per_warp * (size_t) (nbatch_combine + 4) * 4;
+
+    const size_t nbytes_shared_KV = nstages <= 1 ? nbytes_shared_KV_1stage : nbytes_shared_KV_2stage;
+
+    const size_t nbytes_shared_total = std::max(
+        nbytes_shared_combine,
+        Q_in_reg ? std::max(nbytes_shared_Q, nbytes_shared_KV + nbytes_shared_mask)
+                 : nbytes_shared_Q + nbytes_shared_KV + nbytes_shared_mask);
+
+    return nbytes_shared_total;
+}
+
+static bool ggml_cuda_fattn_mma_exceeds_device_shmem_limit(const int device, const ggml_tensor * KQV) {
+    return ggml_cuda_fattn_mma_estimated_dynamic_shmem_bytes(device, KQV) > ggml_cuda_info().devices[device].smpbo;
+}
