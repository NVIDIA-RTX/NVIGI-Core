+size_t ggml_backend_get_cuda_stream_count(ggml_backend_t backend) {
+    if (!ggml_backend_is_cuda(backend)) {
+        return 0;
+    }
+
+    ggml_backend_cuda_context * cuda_ctx = (ggml_backend_cuda_context *) backend->context;
+    size_t                      count    = 0;
+
+    for (int device = 0; device != GGML_CUDA_MAX_DEVICES; device++) {
+        for (int stream = 0; stream != GGML_CUDA_MAX_STREAMS; stream++) {
+            if (cuda_ctx->streams[device][stream] != nullptr) {
+                count++;
+            }
+        }
+    }
+    return count;
+}
+
+size_t ggml_backend_get_cuda_streams(ggml_backend_t backend, void ** cudaStreams, size_t cudaStreamsMaxCount) {
+    if (!ggml_backend_is_cuda(backend)) {
+        return 0;
+    }
+
+    ggml_backend_cuda_context * cuda_ctx = (ggml_backend_cuda_context *) backend->context;
+
+    size_t copied_count = 0;
+    for (int device = 0; device != GGML_CUDA_MAX_DEVICES && copied_count != cudaStreamsMaxCount; device++) {
+        for (int stream = 0; stream != GGML_CUDA_MAX_STREAMS && copied_count != cudaStreamsMaxCount; stream++) {
+            if (cuda_ctx->streams[device][stream] != nullptr) {
+                cudaStreams[copied_count] = cuda_ctx->streams[device][stream];
+                copied_count++;
+            }
+        }
+    }
+
+    return copied_count;
+}
